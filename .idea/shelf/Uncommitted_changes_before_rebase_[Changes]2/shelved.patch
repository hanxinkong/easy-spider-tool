+
+def is_format_element(wait_element_string: Union[str, etree._Element]) -> bool:
+    # noinspection PyBroadException
+    if isinstance(wait_element_string, etree._Element):
+        return True
+    try:
+        etree.HTML(wait_element_string)
+        return True
+    except Exception as _:
+        pass
+    return False
+
+
+def to_dict(src: Union[str, Dict[str, Any]]) -> Dict[str, Any]:
+    if isinstance(src, dict):
+        return src
+
+    return json.loads(src)
+
+
+def to_element(wait_element: Union[str, etree._Element]) -> etree._Element:
